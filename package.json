{
  "name": "monsthera",
  "version": "3.0.0-alpha.0",
  "description": "Knowledge-native development platform for AI coding agents",
  "type": "module",
  "bin": { "monsthera": "dist/index.js" },
  "files": ["dist", "LICENSE", "README.md", "CHANGELOG.md"],
  "scripts": {
    "dev": "tsx watch src/index.ts -- serve",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.6.5",
  "engines": { "node": ">=22" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.25.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.ts": ["eslint --fix", "prettier --write"]
  }
}
