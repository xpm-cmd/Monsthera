{
  "name": "agora",
  "version": "1.0.0",
  "description": "Local, commit-scoped shared context and multi-agent coordination platform for co-coding",
  "type": "module",
  "bin": {
    "agora": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts -- serve",
    "dev:http": "tsx watch src/index.ts -- serve --transport http",
    "build": "tsup",
    "restart": "bash scripts/restart.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "benchmark": "vitest run tests/benchmark/"
  },
  "keywords": [
    "mcp",
    "multi-agent",
    "co-coding",
    "shared-context"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.20.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
