{
  "name": "monsthera-mcp",
  "version": "2.0.12",
  "description": "Give your AI coding agents a shared brain, a backlog, and the ability to work together",
  "type": "module",
  "bin": {
    "monsthera": "dist/index.js"
  },
  "files": [
    "dist",
    ".monsthera/workflows",
    ".monsthera/models",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts -- serve",
    "dev:http": "tsx watch src/index.ts -- serve --transport http",
    "build": "tsup",
    "server:restart": "bash scripts/restart.sh",
    "server:restart:daemon": "bash scripts/restart.sh --daemonize",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/ tests/",
    "download-model": "node scripts/download-model.mjs",
    "prepublishOnly": "pnpm download-model && pnpm build && pnpm typecheck && pnpm test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "coverage": "vitest run --coverage",
    "benchmark": "vitest run tests/benchmark/",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "multi-agent",
    "co-coding",
    "shared-context",
    "cli",
    "code-search",
    "tree-sitter",
    "sqlite",
    "fts5",
    "semantic-search",
    "ai-coding",
    "code-index"
  ],
  "author": "xpm-cmd (https://github.com/xpm-cmd)",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpm-cmd/Monsthera.git"
  },
  "homepage": "https://github.com/xpm-cmd/Monsthera#readme",
  "bugs": {
    "url": "https://github.com/xpm-cmd/Monsthera/issues"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.20.8",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.ts": "eslint"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
