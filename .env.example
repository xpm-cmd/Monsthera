# Agora Office Server Configuration
# Copy this file to .env and adjust values for your setup

# Path to the Agora SQLite database (required)
# Points to the parent Agora repo's database
AGORA_DB_PATH=../.agora/agora.db

# Server port (default: 3001)
PORT=3001

# Polling interval for Agora DB changes in milliseconds (default: 1500)
POLL_INTERVAL_MS=1500

# CORS origin for the client dev server (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
